# theme="starlight"

# https://ghostty.org/docs/config/reference#macos-icon
macos-icon="holographic"

window-padding-x=10
window-padding-y=10
window-padding-color = extend
window-decoration=true

# new window dimensions
window-height = 30
window-width = 120

scrollback-limit = 100000000
mouse-scroll-multiplier=3

mouse-hide-while-typing = true

background-opacity=0.85
background-blur-radius = 20

unfocused-split-opacity = 0.5
unfocused-split-fill = #443344

confirm-close-surface = false


macos-option-as-alt = true

## Keybindings

# see current keybinds with:
# ghostty +list-keybinds
# can reload with default cmd-shift-,

keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

keybind = super+ctrl+h=new_split:left
keybind = super+ctrl+j=new_split:down
keybind = super+ctrl+k=new_split:up
keybind = super+ctrl+l=new_split:right

keybind = alt+ctrl+h=resize_split:left,10
keybind = alt+ctrl+j=resize_split:down,10
keybind = alt+ctrl+k=resize_split:up,10
keybind = alt+ctrl+l=resize_split:right,10