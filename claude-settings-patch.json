{
  "permissions": {
    "allow": [
      "Bash(just)",
      "Bash(just *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git remote)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git check-ignore *)",
      "Bash(git ls-files)",
      "Bash(git ls-files *)",
      "Bash(git ls-tree *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(grep *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(which *)",
      "Bash(command *)",
      "Bash(jq *)"
    ]
  },
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 99999,
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__DOTFILES_DIR__/claude-prompt-submit-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "__DOTFILES_DIR__/claude-statusline.sh"
  }
}
