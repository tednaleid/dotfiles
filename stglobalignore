// syncthing global ignore patterns for ~/code sync between devices
// shared via syncthing, referenced by each device's .stignore via #include

// ===== macOS system files (safe to delete for empty-dir cleanup) =====
(?d).DS_Store
(?d)._*
(?d).Spotlight-V100
(?d).Trashes
(?d).fseventsd
(?d).TemporaryItems
(?d).apdisk
(?d).localized
(?d).metadata_never_index

// ===== Editor temp files (safe to delete) =====
(?d)*.swp
(?d).*.swp
(?d)*~
(?d)*.bak

// ===== Node.js =====
node_modules
.npm
.yarn/cache
.pnp.*
.eslintcache
.next
.nuxt

// ===== Python =====
__pycache__
*.pyc
*.pyo
.venv
venv
*.egg-info
.mypy_cache
.pytest_cache
.tox
.ruff_cache

// ===== Rust =====
target

// ===== Swift/Xcode =====
.build
.swiftpm
DerivedData

// ===== Zig =====
.zig-cache
zig-out

// ===== Java/Kotlin/Gradle =====
build
.gradle
*.class

// ===== Testing =====
.playwright-mcp
playwright-report
test-results
coverage

// ===== Static site generators =====
_site

// ===== General build output =====
dist

// ===== Large ML model files (re-download from source instead of syncing) =====
*.safetensors

// ===== Local tool caches =====
.llm

// ===== Git lock files (prevents blocking git on other machine) =====
.git/**/*.lock

// ===== Syncthing internals =====
.stfolder
.stversions
